{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/marb/submission.schema.json",
  "title": "Market Action Residual Benchmark submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "submission_id",
    "domain_profile",
    "evidence_tier",
    "model",
    "data",
    "controls",
    "task_b",
    "distribution",
    "economic_diagnostic",
    "prospective_status",
    "prohibited_claims_acknowledged"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "submission_id": {"type": "string", "minLength": 1},
    "domain_profile": {"type": "string", "minLength": 1},
    "evidence_tier": {
      "enum": [
        "implemented",
        "executed",
        "replicated_historical",
        "validated_prospective",
        "operational_candidate"
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "code_ref", "artifact_sha256"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "code_ref": {"type": "string", "minLength": 1},
        "artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opportunities", "entities", "agents", "horizons", "test_start", "test_end"],
      "properties": {
        "opportunities": {"type": "integer", "minimum": 1},
        "entities": {"type": "integer", "minimum": 1},
        "agents": {"type": "integer", "minimum": 1},
        "horizons": {"type": "integer", "minimum": 1},
        "test_start": {"type": "string", "format": "date"},
        "test_end": {"type": "string", "format": "date"}
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chronology_locked",
        "candidate_identity_fixed",
        "future_targets_loaded_after_selection",
        "same_agent_future_target",
        "post_event_fields_forbidden"
      ],
      "properties": {
        "chronology_locked": {"const": true},
        "candidate_identity_fixed": {"const": true},
        "future_targets_loaded_after_selection": {"const": true},
        "same_agent_future_target": {"const": true},
        "post_event_fields_forbidden": {"const": true}
      }
    },
    "task_b": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standardized_uplift_slope",
        "cluster_ci_low",
        "cluster_ci_high",
        "placebo_replicates",
        "placebo_upper_tail_p",
        "top_minus_bottom"
      ],
      "properties": {
        "standardized_uplift_slope": {"type": "number"},
        "cluster_ci_low": {"type": "number"},
        "cluster_ci_high": {"type": "number"},
        "placebo_replicates": {"type": "integer", "minimum": 1},
        "placebo_upper_tail_p": {"type": "number", "minimum": 0, "maximum": 1},
        "top_minus_bottom": {"type": "number"}
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "positive_agents",
        "total_agents",
        "positive_instruments",
        "total_instruments",
        "positive_horizons",
        "total_horizons",
        "leave_one_agent_out_min_ci_low"
      ],
      "properties": {
        "positive_agents": {"type": "integer", "minimum": 0},
        "total_agents": {"type": "integer", "minimum": 1},
        "positive_instruments": {"type": "integer", "minimum": 0},
        "total_instruments": {"type": "integer", "minimum": 1},
        "positive_horizons": {"type": "integer", "minimum": 0},
        "total_horizons": {"type": "integer", "minimum": 1},
        "leave_one_agent_out_min_ci_low": {"type": "number"}
      }
    },
    "economic_diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_roi",
        "residual_roi",
        "paired_ci_low_per_opportunity",
        "paired_ci_high_per_opportunity",
        "positive_execution_cells",
        "total_execution_cells",
        "execution_validated"
      ],
      "properties": {
        "raw_roi": {"type": "number"},
        "residual_roi": {"type": "number"},
        "paired_ci_low_per_opportunity": {"type": "number"},
        "paired_ci_high_per_opportunity": {"type": "number"},
        "positive_execution_cells": {"type": "integer", "minimum": 0},
        "total_execution_cells": {"type": "integer", "minimum": 1},
        "execution_validated": {"type": "boolean"}
      }
    },
    "prospective_status": {
      "enum": ["not_started", "in_progress", "failed", "inconclusive", "passed"]
    },
    "prohibited_claims_acknowledged": {"const": true}
  }
}
